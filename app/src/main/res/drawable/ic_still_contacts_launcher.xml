<!-- Monochrome launcher icon: a serif lowercase 'c' on OLED black. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#000000"
        android:pathData="M0,0h108v108h-108z" />
    <!--
        A serif lowercase 'c': open arc on the right, with small terminals at top and bottom.
        Drawn as a single stroked arc (3/4 of a circle) with a hairline finishing flourish on
        each terminal so it reads as a serif glyph rather than a geometric arc.
    -->
    <path
        android:strokeColor="#ECEBE7"
        android:strokeWidth="3.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M72,42 a22,22 0 1 0 0,24" />
    <!-- top terminal serif -->
    <path
        android:strokeColor="#ECEBE7"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M70,42 L76,40" />
    <!-- bottom terminal serif -->
    <path
        android:strokeColor="#ECEBE7"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M70,66 L76,68" />
</vector>
